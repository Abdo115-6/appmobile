#==============================================================================
# YDEVISMOBILE Import Template Definition
# Sage X3 v11 - Import template for mobile devis (quotes)
# CSV delimiter: ";"
# Record types: E = Header, L = Line
#==============================================================================

[IMP]
DESCRIPTION = "YDEVISMOBILE Import"
DELIMITER = ";"
RECORD_TYPES = "E","L"
FIRST_ROW = 1                ; No header row

#------------------------------------------------------------------------------
# E Record (Header / En-tete)
# Fields are positional (1-based index)
#------------------------------------------------------------------------------
[E]
DESCRIPTION = "Header - Devis document"
FIELDS = (
  1: TYPE,         "E",                  fixed,      "Record type"
  2:              (empty),               ignored,    "(empty)"
  3: YSITE_0,      "Site",               char(5),    "Site code (FBC/FMD)"
  4: YDOSSIER_0,   "Dossier",            char(5),    "Dossier / SQN"
  5:              (empty),               ignored,    "(empty)"
  6: YBPCNUM_0,    "ClientCode",         char(20),   "Client code"
  7: YDATE_0,      "Date",               char(8),    "Date (YYYYMMDD)"
  8:              (empty),               ignored,    "(empty)"
  9: YSITEDEV_0,   "SiteLiv",            char(5),    "Delivery site"
  10: YCUR_0,       "Currency",           char(3),    "Currency (MAD)"
  11: YMOBKEY_0,    "MobileKey",          char(20),   "Mobile key (links E to L)"
)

#------------------------------------------------------------------------------
# L Record (Line / Ligne)
# One L record per article in the devis
#------------------------------------------------------------------------------
[L]
DESCRIPTION = "Line - Devis article"
FIELDS = (
  1: TYPE,         "L",                  fixed,      "Record type"
  2:              (empty),               ignored,    "(empty)"
  3: YITMREF_0,    "ArticleRef",         char(30),   "Article reference"
  4: YUNIT_0,      "Unit",               char(5),    "Unit (UN)"
  5: YQTY_0,       "Quantity",           decimal,    "Quantity"
  6: YPRICE_0,     "Price",              decimal,    "Unit price"
  7: YMOBKEY_0,    "MobileKey",          char(20),   "Mobile key (reference to E)"
)

#------------------------------------------------------------------------------
# Validation rules
#------------------------------------------------------------------------------
[RULES]
YSITE_0:       required, must be "FBC" or "FMD"
YBPCNUM_0:     required
YMOBKEY_0(E):  required, unique per import batch
YITMREF_0:     required (L record)
YQTY_0:        required, > 0 (L record)
YPRICE_0:      required, >= 0 (L record)
YMOBKEY_0(L):  must match a preceding E record's YMOBKEY_0
